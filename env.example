# ─── Required ───────────────────────────────────────────────────────────────
# Token MUST include BOTH scopes: data.records:read AND schema.bases:read
AIRTABLE_TOKEN=pat_your_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ─── Layer mapping (this is how the template stays client-agnostic) ──────────
# Map each pin-source table -> a layer. Table IDs recommended (no colons).
# Valid layers: active-sale, active-lease, closed-sale, closed-lease, tenant-rep, buyer-rep
# Tables NOT listed here are treated as internal and never read.
AIRTABLE_LAYER_MAP=tblXXXXXXXXXXXXXX:active-sale,tblYYYYYYYYYYYYYY:active-lease

# ─── Optional ───────────────────────────────────────────────────────────────
# AIRTABLE_TABLE_IDS=tblXXXXXXXXXXXXXX,tblYYYYYYYYYYYYYY   # extra allow-list
# AIRTABLE_LAT_FIELD=Latitude
# AIRTABLE_LNG_FIELD=Longitude
# AIRTABLE_NAME_FIELD=Property Name
# AIRTABLE_HEADLINE_FIELD=Headline
# AIRTABLE_CITY_FIELD=Address — City
# AIRTABLE_IMAGE_FIELD=Hero Image
# AIRTABLE_PRICE_FIELD=Asking Price
# AIRTABLE_META_SECONDARY_FIELDS=Property Type,Year Built
# AIRTABLE_VISIBLE_FIELD=Map Pin Visible

# ─── Worked example: Impact Commercial Group ────────────────────────────────
# AIRTABLE_LAYER_MAP=tblRSY9kLo9sE8Ctb:active-sale,tblYhMRC7nJCThGGk:active-lease
